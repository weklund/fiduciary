#!/usr/bin/env bash
# Pre-commit hook: blocks commits containing financial data or PII.
#
# Install with: git config core.hooksPath .githooks
# Override with: git commit --no-verify (use sparingly)

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0

# --- Check 1: Block data/ files ---
if git diff --cached --name-only | grep -q "^data/"; then
  echo -e "${RED}ERROR: Attempting to commit files from data/ directory.${NC}" >&2
  echo "  These contain sensitive financial transaction data." >&2
  ERRORS=$((ERRORS + 1))
fi

# --- Check 2: Block .db and .sqlite files ---
if git diff --cached --name-only | grep -qE '\.(db|sqlite)$'; then
  echo -e "${RED}ERROR: Attempting to commit database files (.db or .sqlite).${NC}" >&2
  echo "  These contain sensitive financial data." >&2
  ERRORS=$((ERRORS + 1))
fi

# --- Check 3: Check CLAUDE.md Client Context section for dollar amounts ---
# Only flag dollar amounts that appear WITHIN the Client Context section,
# not in the framework/benchmark sections above it.
if git diff --cached --name-only | grep -q "^CLAUDE.md$"; then
  # Extract only the Client Context section from the staged diff
  CLIENT_CONTEXT_DIFF=$(git diff --cached -- CLAUDE.md | sed -n '/^+.*## Client Context/,/^+.*^## /p')
  if echo "$CLIENT_CONTEXT_DIFF" | grep -qE '^\+.*\$[0-9][0-9,]+'; then
    echo -e "${YELLOW}WARNING: CLAUDE.md Client Context section appears to contain dollar amounts.${NC}" >&2
    echo "  This file is git-tracked and PUBLIC. Personal financial data belongs" >&2
    echo "  in memory files (~/.claude/projects/), not in CLAUDE.md." >&2
    echo "  If this is intentional (e.g., updating framework examples), use:" >&2
    echo "    git commit --no-verify" >&2
    ERRORS=$((ERRORS + 1))
  fi
fi

if [ $ERRORS -gt 0 ]; then
  echo "" >&2
  echo -e "${RED}Commit blocked. Fix the issues above or use --no-verify to override.${NC}" >&2
  exit 1
fi

exit 0
